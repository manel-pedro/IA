   "source": [
    "**p)** Implement your Genetic Algorithm.\n",
    "> **Start**: Generate an initial population of solutions.  \n",
    "> **Iterate**:\n",
    "> - Evaluate the fitness of each individual.\n",
    "> - Select parents using fitness-based selection (e.g. tournament or roulette-wheel selection), favoring better solutions.\n",
    "> - Generate offspring through crossover and mutation.\n",
    "> - Form the next generation, reflecting survival of the fittest.\n",
    ">\n",
    "> **Stop**: When the maximum number of generations is reached (or convergence is observed)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a-sx8NiwTXUj",
   "metadata": {
    "id": "a-sx8NiwTXUj"
   },
   "outputs": [],
   "source": [
    "#Helper functions\n",
    "# Generate a population of population_size solutions\n",
    "def generate_population(population_size):\n",
    "    solutions = []\n",
    "    for i in range(population_size):\n",
    "        solutions.append(generate_random_solution())\n",
    "    return solutions\n",
    "\n",
    "#order solutions in the population according to their fitness\n",
    "def order_population(population):\n",
    "    population = copy.deepcopy(population)\n",
    "    ordered_solutions = []\n",
    "    for i in range(len(population)):\n",
    "        ordered_solutions.append([i,evaluate_solution(population[i])])\n",
    "\n",
    "    ordered_solutions.sort(key=lambda x: x[1])\n",
    "    ordered_population = [population[i[0]] for i in ordered_solutions]\n",
    "    return ordered_population\n",
    "\n",
    "#print all the solutions in the population\n",
    "def print_population(population):\n",
    "    solutions = []\n",
    "    for i in range(len(population)):\n",
    "        print(f\"Solution {i}: {population[i]}, {evaluate_solution(population[i])}\")\n",
    "\n",
    "#find the best solution in the population\n",
    "def get_greatest_fit(population):\n",
    "    best_solution = population[0]\n",
    "    best_score = evaluate_solution(population[0])\n",
    "    for i in range(1, len(population)):\n",
    "        score = evaluate_solution(population[i])\n",
    "        if score < best_score:\n",
    "            best_score = score\n",
    "            best_solution = population[i]\n",
    "    return best_solution, best_score\n",
    "\n",
    "#Least fitted individuals are replaced by the solutions of the offspring, if offspring solutions are better than the least fitted\n",
    "def replace_least_fittest(population, offspring):\n",
    "    least_fittest_index = 0\n",
    "    ordered_population = order_population(population)\n",
    "    ordered_offspring = order_population(offspring)\n",
    "\n",
    "    ordered_population = copy.deepcopy(ordered_population)\n",
    "    #how many offspring solutions we generated\n",
    "    k = len(ordered_offspring)\n",
    "\n",
    "    for offspring_solution in ordered_offspring:\n",
    "        score_offspring = evaluate_solution(offspring_solution)  #score the offspring\n",
    "        for j in range(-1, -k - 2, -1):\n",
    "            score_solution = evaluate_solution(ordered_population[j])\n",
    "            if score_offspring >= score_solution:  # if offspring worse than j, insert at j+1\n",
    "                ordered_population.insert(j+1, offspring_solution)\n",
    "                break\n",
    "            else:\n",
    "                continue\n",
    "        else:\n",
    "            ordered_population.insert(-k-1,offspring_solution)  # if for doens't hit the break, we have an edge case where the best offspring is better than all of the least fitted solutions\n",
    "\n",
    "    ordered_population = order_population(ordered_population)\n",
    "\n",
    "    ordered_population = ordered_population[:-k] #truncate to ensure only the best solutions survive in the original population size\n",
    "\n",
    "    return ordered_population"
   ]
  },
