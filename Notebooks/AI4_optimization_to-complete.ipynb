    "**j)** Implement your Simulated Annealing algorithm.\n",
    "> **Start**: Generate an initial solution.  \n",
    "> **Iterate**:  \n",
    "> - Generate a random neighbor.\n",
    "> - Always accept better solutions; may accept worse ones with a probability.\n",
    "> - Worse moves allow the search to cross valleys and escape local optima.\n",
    "> - Acceptance likelihood of worse solutions decreases as the temperature is reduced.\n",
    "> - The best solution is stored, but the search continues from the accepted one.\n",
    ">\n",
    "> **Stop**: When the iterations are exhausted."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "M3EYioTLl8Ek",
   "metadata": {
    "id": "M3EYioTLl8Ek"
   },
   "outputs": [],
   "source": [
    "def get_sa_solution(initial_solution, temperature, cooling_schedule, plateau_limit=50, log=False):\n",
    "    \"\"\"\n",
    "    Arguments:\n",
    "    - initial_solution\n",
    "    - temperature: the initial temperature\n",
    "    - cooling_schedule: a multiplicative value in ]0..1[ to decrease the temperature\n",
    "    - plateau_limit: the number of iterations without improvement to stop the search\n",
    "    - log\n",
    "    Return:\n",
    "    - The best solution found\n",
    "    - Its cost\n",
    "    - The scores trajectory of the solutions adopted along the way\n",
    "    \"\"\"\n",
    "    \n",
    "    current_solution = copy.deepcopy(initial_solution)\n",
    "    current_score = evaluate_solution(initial_solution)\n",
    "    if log:\n",
    "      print(f\"Init Solution:  {current_solution}, score: {current_score}\")\n",
    "    \n",
    "    #to store the trajectory of adopted solution scores\n",
    "    iteration = 0\n",
    "    scores_trajectory = []\n",
    "    scores_trajectory.append([iteration, current_score])\n",
    "    \n",
    "    #counter towards plateau_limit\n",
    "    iterations_since_last_improvement = 0\n",
    "    \n",
    "    #store first init solution as the best score so far\n",
    "    best_solution = copy.deepcopy(current_solution)\n",
    "    best_score = current_score\n",
    "    \n",
    "    # your code here\n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
    "    \n",
